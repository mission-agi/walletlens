{
  "name": "walletlens",
  "version": "1.0.0",
  "private": true,
  "description": "Personal finance dashboard — track spending, investments, and net worth from bank statements",
  "keywords": [
    "personal-finance",
    "budget-tracker",
    "expense-tracker",
    "nextjs",
    "typescript",
    "prisma",
    "tailwindcss"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "DATABASE_URL=file:./test/tmp/unit.db node --import tsx --test --test-concurrency=1 test/unit/**/*.test.ts",
    "test:functional": "DATABASE_URL=file:./test/tmp/functional.db node --import tsx --test --test-concurrency=1 test/functional/**/*.test.ts",
    "test:integration": "npm run build && DATABASE_URL=file:./test/tmp/integration.db node --import tsx --test --test-concurrency=1 test/integration/**/*.test.ts",
    "test:e2e": "npm run build && DATABASE_URL=file:./test/tmp/e2e.db node --import tsx --test --test-concurrency=1 test/e2e/**/*.test.ts",
    "test:e2e:playwright": "DATABASE_URL=file:./test/tmp/playwright.db node test/playwright/run-and-report.mjs",
    "test:all": "node test/run-all.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.mts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
